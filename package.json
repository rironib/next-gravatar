{
  "name": "next-gravatar",
  "version": "1.0.6",
  "description": "Ultra-lightweight Gravatar URL generator for Next.js using SHA-256.",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "repository": "github:rironib/next-gravatar",
  "keywords": [
    "gravatar",
    "nextjs",
    "avatar",
    "profile",
    "image",
    "picture",
    "identifier"
  ],
  "license": "MIT",
  "scripts": {
    "build": "bun build ./index.ts --outfile ./index.js --target node --minify --external js-sha256 && tsc --emitDeclarationOnly --declarationDir ./",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "js-sha256": "^0.11.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
