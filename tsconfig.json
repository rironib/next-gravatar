{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": "./dist",
    "types": ["node", "@types/bun"]
  },
  "include": ["index.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
